generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys ApiKey[]
}

model TestCase {
  id          String   @id @default(uuid())
  title       String
  description String?
  preconditions String?
  url         String?
  steps       String   // JSON string of steps array
  expectedResult String?
  status      String   @default("active") // active | archived
  priority    String   @default("medium") // low | medium | high | critical
  tags        String?  // comma-separated
  script      String?  // generated Playwright script
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  testRuns TestRun[]
  bugs     Bug[]
}

model ApiKey {
  id         String   @id @default(uuid())
  userId     String
  name       String
  keyHash    String   @unique
  keyPreview String
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?
  isActive   Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TestRun {
  id         String   @id @default(uuid())
  testCaseId String
  status     String   @default("pending") // pending | running | passed | failed | error
  duration   Int?     // milliseconds
  logs       String?  // JSON string of log entries
  screenshot String?  // file path
  error      String?
  startedAt  DateTime @default(now())
  finishedAt DateTime?

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  bug      Bug?
}

model Bug {
  id          String   @id @default(uuid())
  testCaseId  String
  testRunId   String   @unique
  title       String
  description String?
  severity    String   @default("medium") // low | medium | high | critical
  status      String   @default("open") // open | in_progress | resolved | closed
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  testRun  TestRun  @relation(fields: [testRunId], references: [id], onDelete: Cascade)
}
