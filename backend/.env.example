# Database - use SQLite for quick setup, PostgreSQL for production
# SQLite (default, no setup needed):
DATABASE_URL="file:./dev.db"

# PostgreSQL (uncomment and fill in for production):
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/testoria?schema=public"

# Server
HOST=127.0.0.1
PORT=3000
NODE_ENV=development

# AI Provider (Ollama is the default local/free option)
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Optional OpenAI fallback
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini

# App Branding (configurable)
APP_NAME=Testoria.ai
APP_VERSION=1.0.0

# Screenshots storage path (relative to backend root)
SCREENSHOTS_DIR=uploads/screenshots
