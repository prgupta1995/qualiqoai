# Database - Prisma Postgres / hosted PostgreSQL
# Preferred standard env var:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Vercel Prisma Postgres may create prefixed variables instead.
# The backend accepts these aliases and maps them to DATABASE_URL at runtime/build time:
# PRISMA_DB_DATABASE_URL="postgresql://..."
# PRISMA_DB_POSTGRES_URL="postgresql://..."
# PRISMA_DB_PRISMA_DATABASE_URL="postgresql://..."

# Server
HOST=127.0.0.1
PORT=3000
NODE_ENV=development

# AI Provider (Ollama is the default local/free option)
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Optional OpenAI fallback
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini

# App Branding (configurable)
APP_NAME=Testoria.ai
APP_VERSION=1.0.0

# Screenshots storage path (relative to backend root)
SCREENSHOTS_DIR=uploads/screenshots
