{
  "name": "backend",
  "version": "1.0.0",
  "description": "Testoria.ai - AI-powered QA Automation Platform Backend",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "node scripts/prisma-command.js generate",
    "vercel-build": "node scripts/prisma-command.js generate",
    "postinstall": "node scripts/postinstall.js",
    "browsers:install": "node scripts/install-playwright.js",
    "db:migrate": "prisma migrate dev --name init",
    "db:generate": "node scripts/prisma-command.js generate",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "db:push": "node scripts/prisma-command.js db push",
    "setup": "npm install && npm run db:generate && npm run db:push && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.28.0",
    "playwright": "^1.42.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0"
  }
}
